{
  "plugin_id": "com.solosoul.official.phone-fmt",
  "name": "Phone Formatter",
  "version": "1.0.2",
  "plugin_api_version": "1.0",
  "min_app_version": "1.0.0",
  "max_app_version": "999.999.999",
  "description": "电话格式化器 — 按国家规范格式化电话号码（中/美/英/日等）",
  "publisher": "SoloSoul Official",
  "homepage": "https://github.com/Gczmy/SoloSoul_plugin_market/tree/main/plugins/com.solosoul.official.phone-fmt",
  "required_fields": [
    "contact.phone"
  ],
  "optional_fields": [
    "address.country"
  ],
  "network_policy": {
    "block_all_outbound": true
  },
  "data_ttl_seconds": 60,
  "require_user_confirmation": false,
  "i18n": {
    "zh": {
      "name": "电话格式化",
      "description": "按目标国家/地区规范格式化电话号码。"
    },
    "en": {
      "name": "Phone Formatter",
      "description": "Format phone numbers from the Vault according to target country/region dialing standards."
    }
  }
}
