{
  "plugin_id": "com.solosoul.official.packing-list",
  "name": "Packing List",
  "version": "1.0.1",
  "plugin_api_version": "1.0",
  "min_app_version": "1.0.0",
  "max_app_version": "999.999.999",
  "description": "行李清单生成器 — 根据目的地和季节智能推荐旅行打包清单",
  "publisher": "SoloSoul Official",
